void sendATCommand(const char* command) {
    char response[RESPONSE_BUFFER_SIZE];
    memset(response, 0, RESPONSE_BUFFER_SIZE);

    // Send the AT command
    HAL_UART_Transmit(&huart2, command, strlen(command), 2000);
    //strcat("Transmitted --> ", command);
    CDC_Transmit_FS(command, strlen(command));

    // Wait for the response
    HAL_UART_Receive(&huart2, response, RESPONSE_BUFFER_SIZE, 2000); // 5000 ms timeout
    //strcat("Received --> ", response);
    CDC_Transmit_FS(response, strlen(response));

}

